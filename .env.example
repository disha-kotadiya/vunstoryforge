# Copy this file to `.env` and fill in your keys.
# Vite only exposes vars prefixed with VITE_ to the browser.

# Google Gemini — TEXT generation: concepts & scripts.
# Use a key from a project with NO billing to stay on the free tier.
# (https://aistudio.google.com/apikey → "Create API key in new project")
VITE_GEMINI_TEXT_API_KEY=AIza...

# Google Gemini — IMAGE generation (paid: requires a funded Google project).
VITE_GEMINI_API_KEY=AIza...
